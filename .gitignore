# ──────────────────────────────────────────────────────────────
# WayMaker .gitignore
# 이 리포지토리는 PUBLIC 입니다. 기획/내부/민감 정보는 절대 커밋되지 않습니다.
# 규칙 상세는 CLAUDE.md 참고.
# ──────────────────────────────────────────────────────────────

# === 내부 기획 / 민감 문서 (절대 커밋 금지) ===
docs/internal/
docs/private/
*.private.md
*.secret.*
NOTES.local.md
scratch/

# === Claude / AI 작업 부산물 ===
.claude/memory/
memory/
*.local.md

# === 환경 변수 / 비밀 ===
.env
.env.*
!.env.example

# === Node / Next.js (추후 스캐폴딩 대비) ===
node_modules/
.next/
out/
build/
dist/
.turbo/
*.tsbuildinfo
next-env.d.ts

# === 패키지 매니저 로그 ===
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# === 테스트 / 커버리지 ===
coverage/
.nyc_output/

# === OS / 에디터 ===
.DS_Store
Thumbs.db
*.swp
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# === 사용자 데이터 샘플 (실제 교회 배선 정보가 들어갈 수 있음) ===
*.waymap.local.json
sample-data/private/
